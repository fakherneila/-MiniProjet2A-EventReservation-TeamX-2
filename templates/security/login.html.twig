{% extends "base.html.twig" %}

{% block title %}Log in{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3>Login</h3>
                </div>
                <div class="card-body">
                    <form method="post">
                        {% if error %}
                            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, "security") }}</div>
                        {% endif %}

                        <div class="mb-3">
                            <label for="username" class="form-label">Email</label>
                            <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" required autofocus>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" name="_password" id="password" class="form-control" required>
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token("authenticate") }}">

                        <button class="btn btn-primary" type="submit">Sign in</button>
                        <a href="{{ path("app_register") }}" class="btn btn-link">Register</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
