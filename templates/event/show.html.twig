{% extends "base.html.twig" %}

{% block title %}{{ event.title }} - Event Details{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">{{ event.title }}</li>
                </ol>
            </nav>
            
            <div class="card shadow-sm">
                <img src="{{ event.image }}" class="card-img-top" alt="{{ event.title }}" style="height: 400px; object-fit: cover;">
                
                <div class="card-body">
                    <h1 class="card-title">{{ event.title }}</h1>
                    
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="info-item p-3 border rounded">
                                <i class="fas fa-calendar-alt fa-2x text-primary mb-2"></i>
                                <div>
                                    <strong>Date & Time</strong><br>
                                    {{ event.date|date("F d, Y H:i") }}
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="info-item p-3 border rounded">
                                <i class="fas fa-map-marker-alt fa-2x text-danger mb-2"></i>
                                <div>
                                    <strong>Location</strong><br>
                                    {{ event.location }}
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="info-item p-3 border rounded">
                                <i class="fas fa-users fa-2x text-success mb-2"></i>
                                <div>
                                    <strong>Available Seats</strong><br>
                                    <span class="badge bg-{% if event.availableSeats > 50 %}success{% elseif event.availableSeats > 20 %}warning{% else %}danger{% endif %} fs-6">
                                        {{ event.availableSeats }} / {{ event.seats }}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <h4>About This Event</h4>
                        <p class="lead">{{ event.description }}</p>
                    </div>
                    
                    <div class="text-center mt-4">
                        <a href="/" class="btn btn-secondary btn-lg me-2">
                            <i class="fas fa-arrow-left"></i> Back to Events
                        </a>
                        {% if event.availableSeats > 0 %}
                            <button class="btn btn-success btn-lg" 
                                    onclick="openReservationModal(
                                        '{{ event.id }}', 
                                        '{{ event.title }}', 
                                        '{{ event.date|date("F d, Y H:i") }}', 
                                        '{{ event.location }}'
                                    )">
                                <i class="fas fa-ticket-alt"></i> Reserve Now
                            </button>
                        {% else %}
                            <button class="btn btn-danger btn-lg" disabled>
                                <i class="fas fa-ban"></i> Fully Booked
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    {% include 'event/reserve_modal.html.twig' %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function showToast(message, type) {
            // You can implement toast notifications here
            console.log(message);
        }
    </script>
{% endblock %}
