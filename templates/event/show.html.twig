{% extends "base.html.twig" %}

{% block title %}{{ event.title }} - Event Details{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">{{ event.title }}</li>
                </ol>
            </nav>
            
            <div class="event-detail-card">
                <img src="{{ event.image }}" class="event-image" alt="{{ event.title }}">
                
                <div class="event-info">
                    <h1 class="mb-4">{{ event.title }}</h1>
                    
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="info-item">
                                <i class="fas fa-calendar-alt"></i>
                                <div>
                                    <strong>Date & Time</strong><br>
                                    {{ event.date|date("F d, Y H:i") }}
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-item">
                                <i class="fas fa-map-marker-alt"></i>
                                <div>
                                    <strong>Location</strong><br>
                                    {{ event.location }}
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-item">
                                <i class="fas fa-users"></i>
                                <div>
                                    <strong>Available Seats</strong><br>
                                    <span class="badge bg-{% if event.availableSeats > 50 %}success{% elseif event.availableSeats > 20 %}warning{% else %}danger{% endif %}">
                                        {{ event.availableSeats }} / {{ event.seats }}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <h4>Event Description</h4>
                        <p class="lead">{{ event.description }}</p>
                    </div>
                    
                    <div class="text-center">
                        <a href="/" class="btn btn-secondary me-2">
                            <i class="fas fa-arrow-left"></i> Back to Events
                        </a>
                        {% if event.availableSeats > 0 %}
                            <button class="btn btn-success" onclick="showReservationModal()">
                                <i class="fas fa-ticket-alt"></i> Reserve Now
                            </button>
                        {% else %}
                            <button class="btn btn-danger" disabled>
                                <i class="fas fa-ban"></i> Fully Booked
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
<script>
function showReservationModal() {
    alert('🎉 Reservation System Demo!\n\nThis is a demonstration of the event reservation system.\n\nIn production, this would open a reservation form where you could:\n- Enter your name\n- Provide email address\n- Add phone number\n- Confirm reservation\n\nThank you for using Event Reservation System!');
}
</script>
{% endblock %}
