{% extends "base.html.twig" %}

{% block hero %}
<div class="hero-section">
    <div class="container text-center">
        <h1 class="display-4">Discover Amazing Events</h1>
        <p class="lead">Find and reserve seats for the most exciting events near you</p>
        <div class="row justify-content-center mt-4">
            <div class="col-md-6">
                <form method="get" class="search-box">
                    <div class="input-group">
                        <input type="text" name="search" class="form-control form-control-lg" 
                               placeholder="Search by event title or location..." value="{{ search }}">
                        <button class="btn btn-primary btn-lg" type="submit">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block body %}
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Upcoming Events</h2>
            <p class="text-muted">Found {{ totalEvents }} event(s)</p>
        </div>
    </div>

    <div class="row">
        {% for event in events %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="{{ event.image }}" class="card-img-top" alt="{{ event.title }}" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title">{{ event.title }}</h5>
                        <p class="card-text text-muted">{{ event.description|slice(0, 100) }}...</p>
                        <div class="mb-2">
                            <small class="text-muted">
                                <i class="fas fa-calendar-alt"></i> {{ event.date|date("M d, Y") }}<br>
                                <i class="fas fa-map-marker-alt"></i> {{ event.location }}<br>
                                <i class="fas fa-users"></i> 
                                <span class="badge bg-{% if event.availableSeats > 50 %}success{% elseif event.availableSeats > 20 %}warning{% else %}danger{% endif %}">
                                    {{ event.availableSeats }} seats available
                                </span>
                            </small>
                        </div>
                        <button class="btn btn-primary w-100" 
                                onclick="openReservationModal(
                                    '{{ event.id }}', 
                                    '{{ event.title|escape('js') }}', 
                                    '{{ event.date|date("F d, Y H:i") }}', 
                                    '{{ event.location|escape('js') }}'
                                )">
                            <i class="fas fa-ticket-alt"></i> Reserve Now
                        </button>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle fa-2x mb-3"></i>
                    <h4>No events found</h4>
                    <p>Try adjusting your search or check back later for new events.</p>
                    <a href="/" class="btn btn-primary">Clear Search</a>
                </div>
            </div>
        {% endfor %}
    </div>

    {% if totalPages > 1 %}
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                {% if currentPage > 1 %}
                    <li class="page-item">
                        <a class="page-link" href="/?page={{ currentPage - 1 }}&search={{ search }}">
                            <i class="fas fa-chevron-left"></i> Previous
                        </a>
                    </li>
                {% endif %}
                
                {% for i in 1..totalPages %}
                    <li class="page-item {% if i == currentPage %}active{% endif %}">
                        <a class="page-link" href="/?page={{ i }}&search={{ search }}">{{ i }}</a>
                    </li>
                {% endfor %}
                
                {% if currentPage < totalPages %}
                    <li class="page-item">
                        <a class="page-link" href="/?page={{ currentPage + 1 }}&search={{ search }}">
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                {% endif %}
            </ul>
        </nav>
    {% endif %}
    
    <div class="text-center text-muted mt-3">
        <small>Showing {{ events|length }} of {{ totalEvents }} events</small>
    </div>
    
    {% include 'event/reserve_modal.html.twig' %}
{% endblock %}
